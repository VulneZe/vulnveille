# Docker Compose override pour le développement local
# Renommer ce fichier en docker-compose.override.yml pour l'utiliser
# Ce fichier expose les services sur localhost pour un test rapide
# NE PAS UTILISER EN PRODUCTION

version: '3.8'

services:
  # FreshRSS - Exposé sur localhost:8081 pour le développement
  freshrss:
    ports:
      - "8081:80"

  # n8n - Exposé sur localhost:5678 pour le développement
  n8n:
    ports:
      - "5678:5678"

  # changedetection.io - Exposé sur localhost:5000 pour le développement
  changedetection:
    ports:
      - "5000:5000"

  # Wallabag - Exposé sur localhost:8082 pour le développement
  wallabag:
    ports:
      - "8082:80"

# Pour utiliser ce fichier :
# 1. Copier docker-compose.override.yml.example en docker-compose.override.yml
# 2. Démarrer avec : docker compose up -d
# 3. Accéder aux services :
#    - FreshRSS : http://localhost:8081
#    - n8n : http://localhost:5678
#    - changedetection.io : http://localhost:5000
#    - Wallabag : http://localhost:8082
#
# Pour la production :
# - Ne pas utiliser docker-compose.override.yml
# - Utiliser docker-compose.prod.yml à la place
