# Configuration de la plateforme de veille techno-cyber
# Copier ce fichier en .env et ajuster les valeurs
# NE JAMAIS COMMITTER .env

# ============================================================================
# Configuration générale
# ============================================================================
TZ=Europe/Paris
PROJECT_NAME=veille-techno-cyber-interne
INTERNAL_DOMAIN=veille.local

# ============================================================================
# Noms de domaine internes (à configurer dans le DNS interne)
# ============================================================================
FRESHRSS_FQDN=freshrss.veille.local
N8N_FQDN=n8n.veille.local
CHANGEDETECTION_FQDN=changes.veille.local
WALLABAG_FQDN=wallabag.veille.local

# ============================================================================
# Configuration PostgreSQL
# ============================================================================
POSTGRES_USER=veille
POSTGRES_PASSWORD=CHANGEZ_CECI_MOT_DE_PASSE_FORT_POSTGRES
POSTGRES_DB=veille
POSTGRES_DB_N8N=n8n
POSTGRES_DB_WALLABAG=wallabag

# ============================================================================
# Configuration n8n
# ============================================================================
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGEZ_CECI_MOT_DE_PASSE_FORT_N8N
N8N_ENCRYPTION_KEY=CHANGEZ_CECI_CLE_DE_CHIFFREMENT_N8N_MIN_32_CARACTERES
N8N_HOST=n8n.veille.local
N8N_PROTOCOL=http
N8N_PORT=5678
N8N_EDITOR_BASE_URL=http://n8n.veille.local
WEBHOOK_URL=http://n8n.veille.local/

# ============================================================================
# Configuration Wallabag
# ============================================================================
WALLABAG_DATABASE_USER=wallabag
WALLABAG_DATABASE_PASSWORD=CHANGEZ_CECI_MOT_DE_PASSE_FORT_WALLABAG
WALLABAG_DATABASE_NAME=wallabag
WALLABAG_SECRET=CHANGEZ_CECI_SECRET_WALLABAG_MIN_32_CARACTERES
WALLABAG_MAILER_DSN=smtp://localhost:25
WALLABAG_FROM_EMAIL=wallabag@veille.local

# ============================================================================
# Configuration FreshRSS
# ============================================================================
FRESHRSS_ADMIN_USER=admin
FRESHRSS_ADMIN_PASSWORD=CHANGEZ_CECI_MOT_DE_PASSE_FORT_FRESHRSS

# ============================================================================
# Configuration changedetection.io (optionnel)
# ============================================================================
# PAGETELEGRAM_NOTIFICATION_URL=  # Pour notifications Telegram
# PLAYWRIGHT_DRIVER_URL=  # Pour JavaScript rendering
